+            version: number;
+            high: number[];
+            tilesets: ProcessedTileset[];
+            animations: { [tileId: number]: ProcessedAnimation[] };
+        },
+        mapId: string
+    ): void {
+        this.mapId = mapId;
+        this.width = mapData.width;
+        this.height = mapData.height;
+        this.tileSize = mapData.tileSize;
+        this.high = mapData.high;
+        this.rawTilesets = mapData.tilesets;
+        this.animatedTiles = mapData.animations;
+
+        Utils.tileSize = this.tileSize;
+        Utils.sideLength = this.width / Modules.Constants.MAP_DIVISION_SIZE;
+        Utils.halfTile = this.tileSize / 2;
+        Utils.tileAndAQuarter = this.tileSize * 1.25;
+
+        this.game.camera.setMapSize(this.width, this.height, this.tileSize);
+    }
+
