+    /**
+     * Loads another map's client metadata and reinitializes grids/tilesets.
+     * @param clientFile Filename under /data/maps/.
+     * @param mapId Registered map identifier.
+     * @param callback Invoked once preliminary map data is ready.
+     */
+
+    public switchMap(
+        clientFile: string,
+        mapId: string,
+        callback: () => void,
+        onError?: () => void
+    ): void {
+        fetch(`/data/maps/${clientFile}`)
+            .then((response) => {
+                if (!response.ok) throw new Error(`Failed to load map file ${clientFile}`);
+
+                return response.json();
+            })
+            .then((mapData) => {
+                this.applyMetadata(mapData, mapId);
+
+                this.game.storage.clear();
+                this.game.storage.clearIndexedDB();
+
+                this.mapLoaded = false;
+                this.tilesetsLoaded = false;
+                this.regionsLoaded = 0;
+                this.data = [];
+                this.tilesets = [];
+                this.dynamicAnimatedTiles = {};
+
+                this.grids = new Grids(this);
+                this.loadGrid();
+                this.loadTilesets();
+
+                this.readyCallback = () => {
+                    if (this.game.useWebGl) this.game.renderer.load();
+
+                    this.game.bindMapGrids();
+
+                    callback();
+                };
+                this.ready();
+            })
+            .catch((error: Error) => {
+                log.error(error.message);
+                onError?.();
+            });
+    }
+
+    /**
+     * Applies client-side map metadata from a JSON export.
+     */
+
